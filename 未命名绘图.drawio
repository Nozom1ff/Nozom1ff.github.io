        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1174" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#4A148C;fontFamily=Times New Roman;" value="How Layers Use Operators: Implementation Pattern" vertex="1">
          <mxGeometry height="35" width="860" x="3160" y="1740" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1175" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7B1FA2;align=left;verticalAlign=top;spacingLeft=10;fontSize=12;fontFamily=Times New Roman;" value="Linear Layer&#xa;&#xa;class Linear : public Layer {&#xa;  Parameter weight_, bias_;&#xa;&#xa;  Tensor forward(const Tensor&amp; x) {&#xa;    auto y = mat_mul(x, weight_);&#xa;    y = y + broadcast_to(bias_);&#xa;    return y;&#xa;  }&#xa;};&#xa;&#xa;• Owns: weight, bias&#xa;• Calls: mat_mul, add operators" vertex="1">
          <mxGeometry height="220" width="240" x="3170" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1176" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#7B1FA2;align=left;verticalAlign=top;spacingLeft=10;fontSize=12;fontFamily=Times New Roman;" value="ReLU Layer&#xa;&#xa;class ReLU : public Layer {&#xa;  Tensor forward(const Tensor&amp; x) {&#xa;    return relu(x);&#xa;  }&#xa;};&#xa;&#xa;• No parameters&#xa;• Wrapper for relu operator&#xa;• Stateless layer" vertex="1">
          <mxGeometry height="220" width="200" x="3440" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1177" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ba68c8;strokeColor=#7B1FA2;align=left;verticalAlign=top;spacingLeft=10;fontSize=12;fontFamily=Times New Roman;" value="Conv2d Layer&#xa;&#xa;class Conv2d : public Layer {&#xa;  Parameter weight_, bias_;&#xa;  pair&lt;int,int&gt; stride_, pad_;&#xa;&#xa;  Tensor forward(const Tensor&amp; x) {&#xa;    return conv2d(x, weight_, &#xa;                &amp;bias_, stride_, pad_);&#xa;  }&#xa;};&#xa;&#xa;• Owns: weight, bias, stride, pad&#xa;• Calls: conv2d operator" vertex="1">
          <mxGeometry height="220" width="230" x="3670" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1178" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#E91E63;strokeWidth=3;" value="" vertex="1">
          <mxGeometry height="400" width="700" x="2200" y="2065" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1179" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#880E4F;fontFamily=Times New Roman;" value="Operator Lifecycle: From Creation to Backward" vertex="1">
          <mxGeometry height="35" width="660" x="2220" y="2080" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1180" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8bbd0;strokeColor=#E91E63;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Phase 1: Creation&#xa;&#xa;• Created on heap&#xa;  new Add()&#xa;• Wrapped in shared_ptr&#xa;• Constructor saves params&#xa;  Conv2dOp(stride, pad)" vertex="1">
          <mxGeometry height="100" width="280" x="2240" y="2130" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1181" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f48fb1;strokeColor=#E91E63;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Phase 2: Forward&#xa;&#xa;• Save inputs&#xa;• Call forward()&#xa;• Compute via Mat&#xa;• Create Tensor&#xa;• Set requires_grad&#xa;• Set creator&#xa;• Build graph" vertex="1">
