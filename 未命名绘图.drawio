          <mxGeometry height="210" width="120" x="2800" y="1790" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1172" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#43a047;strokeColor=#388E3C;align=center;fontSize=13;fontFamily=Times New Roman;" value="Pooling&#xa;&#xa;max_pool2d&#xa;avg_pool2d&#xa;adaptive_avg" vertex="1">
