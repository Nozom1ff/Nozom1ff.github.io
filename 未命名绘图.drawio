        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1083" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#FF9800;align=left;verticalAlign=top;spacingLeft=10;fontSize=14;fontFamily=Times New Roman;" value="Key Members:&lt;br&gt;&lt;br&gt;• inputs_: vector&lt;br&gt;  Stores input tensors (by value)&lt;br&gt;&lt;br&gt;• outputs_: vector&lt;br&gt;  Avoids circular reference&lt;br&gt;&lt;br&gt;• generation_: int&lt;br&gt;  Topological order for sorting" vertex="1">
          <mxGeometry height="220" width="210" x="885" y="1730" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1084" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#FF9800;align=left;verticalAlign=top;spacingLeft=10;fontSize=14;fontFamily=Times New Roman;" value="Key Methods:&#xa;&#xa;• forward(inputs):&#xa;  Computes output tensors&#xa;&#xa;• backward(grad_outputs):&#xa;  Computes input gradients&#xa;&#xa;• operator()(inputs):&#xa;  - Calls forward()&#xa;  - Sets requires_grad&#xa;  - Sets creator&#xa;  - Builds graph" vertex="1">
          <mxGeometry height="220" width="210" x="1115" y="1730" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1085" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#E91E63;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="210" width="500" x="855" y="1990" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1086" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#C2185B;fontFamily=Times New Roman;" value="Why weak_ptr for outputs_?" vertex="1">
          <mxGeometry height="25" width="460" x="875" y="2005" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1087" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=15;fontColor=#C2185B;fontFamily=Times New Roman;" value="Problem: Circular reference&lt;br&gt;  Operator -&amp;gt; outputs_ -&amp;gt; Tensor -&amp;gt; creator_ -&amp;gt; Operator&lt;br&gt;&lt;br&gt;Solution: Use &lt;b&gt;weak_ptr in outputs_&lt;/b&gt;&lt;br&gt;  • Operator observes outputs (doesn&#39;t own them)&lt;br&gt;  • Breaks the cycle, prevents memory leak&lt;br&gt;  • In backward(), convert to shared_ptr if valid" vertex="1">
          <mxGeometry height="80" width="460" x="885" y="2040" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1088" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7B1FA2;strokeWidth=3;arcSize=11;" value="" vertex="1">
