        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1173" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7B1FA2;strokeWidth=3;" value="" vertex="1">
