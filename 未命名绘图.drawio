        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1162" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#0D47A1;fontFamily=Times New Roman;" value="Layer vs Operator: Key Differences" vertex="1">
          <mxGeometry height="35" width="860" x="3160" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1163" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1976D2;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Layer (High-Level)&#xa;&#xa;Characteristics:&#xa;• Stateful (has parameters)&#xa;• Long-lived object&#xa;• Reusable across batches&#xa;• Manages learnable weights&#xa;• Part of model architecture&#xa;&#xa;Examples:&#xa;• Linear(in=10, out=20)&#xa;• Conv2d(in=3, out=64)&#xa;• BatchNorm2d(num=128)&#xa;&#xa;Usage:&#xa;Layer layer = Linear(10, 20);&#xa;for (batch : data) {&#xa;  out = layer.forward(batch);&#xa;}" vertex="1">
          <mxGeometry height="290" width="380" x="3190" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1164" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#64b5f6;strokeColor=#1976D2;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Operator (Low-Level)&#xa;&#xa;Characteristics:&#xa;• Stateless (no persistent data)&#xa;• Ephemeral (created per call)&#xa;• Single-use computation&#xa;• Only stores forward inputs&#xa;• Used by Layers internally&#xa;&#xa;Examples:&#xa;• Add, Sub, Mul, Div&#xa;• MatMul, Conv2dOp&#xa;• ReLU, Sigmoid&#xa;• Reshape, Transpose&#xa;&#xa;Usage:&#xa;z = (*shared_ptr&lt;Op&gt;(new Add()))({x, y})[0];&#xa;// Op deleted after z created" vertex="1">
          <mxGeometry height="290" width="390" x="3610" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1165" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388E3C;strokeWidth=3;" value="" vertex="1">
          <mxGeometry height="300" width="900" x="2200" y="1725" as="geometry" />
        </mxCell>
