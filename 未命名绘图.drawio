        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1170" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#66bb6a;strokeColor=#388E3C;align=center;fontSize=13;fontFamily=Times New Roman;" value="NN Ops&#xa;&#xa;dropout&#xa;embedding&#xa;upsample&#xa;identity&#xa;yolo_detect" vertex="1">
