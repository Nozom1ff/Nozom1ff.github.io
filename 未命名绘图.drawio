        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1152" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#E65100;fontFamily=Times New Roman;" value="Class Hierarchy: Foundation of the System" vertex="1">
          <mxGeometry height="35" width="860" x="2220" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1153" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#FF9800;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Module (Abstract Base)&#xa;&#xa;Core Responsibilities:&#xa;• Parameter management&#xa;• Sub-module composition&#xa;• Training/eval state&#xa;• Device management&#xa;• state_dict() / load_state_dict()&#xa;&#xa;Key Members:&#xa;• parameters_: map&lt;name, Parameter*&gt;&#xa;• modules_: map&lt;name, unique_ptr&lt;Module&gt;&gt;&#xa;• training_: bool&#xa;&#xa;Pure Virtual:&#xa;• forward(input) = 0" vertex="1">
          <mxGeometry height="290" width="200" x="2240" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1154" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#FF9800;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Layer : public Module&#xa;&#xa;(Empty base class)&#xa;Type distinction only&#xa;&#xa;Purpose:&#xa;• Neural network layers&#xa;• With learnable parameters&#xa;• Stateful computations" vertex="1">
          <mxGeometry height="140" width="180" x="2480" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1155" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffb74d;strokeColor=#FF9800;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Concrete Layers:&#xa;&#xa;• Linear: weight_, bias_&#xa;• Conv2d: weight_, bias_&#xa;• BatchNorm: gamma_, beta_&#xa;• Embedding: weight_&#xa;• Dropout: p_ (no params)&#xa;• ReLU, etc.: Stateless&#xa;&#xa;• Sequential: Container" vertex="1">
          <mxGeometry height="135" width="260" x="2480" y="1525" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1156" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1976D2;align=left;verticalAlign=top;spacingLeft=10;fontSize=13;fontFamily=Times New Roman;" value="Operator (Abstract Base)&#xa;: public enable_shared_from_this&#xa;&#xa;Core Responsibilities:&#xa;• Computation graph node&#xa;• Forward/backward logic&#xa;• Input storage&#xa;&#xa;Key Members:&#xa;• inputs_: vector&lt;Tensor&gt;&#xa;• outputs_: vector&lt;weak_ptr&lt;...&gt;&gt;&#xa;• generation_: int (topo order)&#xa;&#xa;Pure Virtual:&#xa;• forward(inputs) = 0&#xa;• backward(grad_outputs) = 0&#xa;&#xa;Key Method:&#xa;• operator()(inputs): Builds graph" vertex="1">
          <mxGeometry height="290" width="280" x="2780" y="1370" as="geometry" />
        </mxCell>
