        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1129" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#F57F17;fontFamily=Times New Roman;" value="Memory Management After Backward" vertex="1">
          <mxGeometry height="25" width="370" x="910" y="2770" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1130" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=15;fontColor=#F57F17;fontFamily=Times New Roman;" value="• Clear operator inputs_ (frees input tensors)&#xa;• Clear intermediate tensor grad_ and creator_&#xa;• Keep output tensor grad_ (z.grad for user)&#xa;• Keep input tensor grad_ (x0.grad, x1.grad, ...)&#xa;• Prevents memory leak from circular references" vertex="1">
          <mxGeometry height="80" width="370" x="915" y="2800" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1150" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontFamily=Times New Roman;" value="OriginDL Operator &amp; Layer System Architecture" vertex="1">
          <mxGeometry height="50" width="1000" x="2620" y="1225" as="geometry" />
