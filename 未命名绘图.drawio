        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1082" parent="aN83DGbymWm0B96Egb2V-1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#E65100;fontFamily=Times New Roman;" value="Operator Class: Core Component" vertex="1">
