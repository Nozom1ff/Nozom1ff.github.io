        <mxCell id="Y7E202aNp6UPut6J14ll-275" parent="aN83DGbymWm0B96Egb2V-1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;autosizeText=1;fontSize=11;" value="为什么layers 用 shared_ptr: 容器操作的便利性&lt;br&gt;&lt;br&gt;&amp;nbsp; // vector 中 shared_ptr 更容易处理&lt;br&gt;&amp;nbsp; llama_layers_-&amp;gt;wq_layers_.push_back(wq);&amp;nbsp; // 直接 push&lt;br&gt;&amp;nbsp; llama_layers_-&amp;gt;wq_layers_.at(i);&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // 随意访问和复制&lt;br&gt;&lt;br&gt;&amp;nbsp; // 如果用 unique_ptr&lt;br&gt;&amp;nbsp; llama_layers_-&amp;gt;wq_layers_.push_back(std::move(wq));&amp;nbsp; // 必须 move&lt;br&gt;&amp;nbsp; auto layer = std::move(llama_layers_-&amp;gt;wq_layers_.at(i));&amp;nbsp; // 取出也会转移所有权" vertex="1">
          <mxGeometry height="220" width="330" x="-1510" y="1225" as="geometry" />
        </mxCell>
        <mxCell id="Y7E202aNp6UPut6J14ll-276" parent="aN83DGbymWm0B96Egb2V-1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;autosizeText=1;fontSize=6;align=left;" value="&lt;div align=&quot;left&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;// 访问 layer 的 weight 的时候 cast 是按类型的&lt;/font&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;const void* RawModelDataFp32::weight(size_t offset) const {&lt;br&gt;&amp;nbsp; return static_cas&lt;span style=&quot;color: rgb(255, 51, 51);&quot;&gt;t&amp;lt;float*&amp;gt;&lt;/span&gt;(weight_data) + offset;&lt;br&gt;}&lt;br&gt;const void* RawModelDataInt8::weight(size_t offset) const {&lt;br&gt;&amp;nbsp; return static_cast&amp;lt;int8_t*&amp;gt;(weight_data) + offset;&lt;br&gt;}&lt;/font&gt;&lt;/div&gt;" vertex="1">
