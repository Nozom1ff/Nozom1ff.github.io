        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1127" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388E3C;align=left;verticalAlign=top;spacingLeft=10;fontSize=16;fontFamily=Times New Roman;" value="1. z.backward()&#xa;2. Mul::backward(gz=1) -&amp;gt; returns [grad_add, grad_sub]&#xa;3. Add::backward(grad_add) -&amp;gt; returns [gx0, gx1]&#xa;4. Sub::backward(grad_sub) -&amp;gt; returns [gx2, gx3]" vertex="1">
          <mxGeometry height="85" width="400" x="895" y="2645" as="geometry" />
        </mxCell>
        <mxCell id="0BqmxJm_ZGjpQhJTHVKr-1128" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#FBC02D;strokeWidth=2;" value="" vertex="1">
