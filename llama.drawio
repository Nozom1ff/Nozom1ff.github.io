        <mxCell id="O23gL1ym4Lucq9g-aiCs-99" parent="aN83DGbymWm0B96Egb2V-1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 8;strokeColor=#CC99FF;strokeWidth=2;align=left;" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 14px;&quot;&gt;struct LLama2Layers {&lt;br&gt;&amp;nbsp; std::shared_ptr&amp;lt;op::Layer&amp;gt; add_layer_;&lt;br&gt;&amp;nbsp; std::shared_ptr&amp;lt;op::Layer&amp;gt; rope_layer_;&lt;br&gt;&amp;nbsp; std::shared_ptr&amp;lt;op::Layer&amp;gt; swiglu_layer_;&lt;br&gt;&amp;nbsp; std::shared_ptr&amp;lt;op::Layer&amp;gt; mha_layer_;&lt;br&gt;// 下面大部分都是 &lt;span style=&quot;color: rgb(102, 102, 255);&quot;&gt;MatmulLayer&lt;/span&gt;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; wq_layers_;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; wk_layers_;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; wv_layers_;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; wo_layers_;&lt;br&gt;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; w1_layers_;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; w2_layers_;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; rmsnorm_layers_;&lt;br&gt;&amp;nbsp; std::vector&amp;lt;std::shared_ptr&amp;lt;op::Layer&amp;gt;&amp;gt; w3_layers_;&lt;br&gt;&amp;nbsp; std::shared_ptr&amp;lt;op::Layer&amp;gt; cls_layer_;&lt;br&gt;&lt;br&gt;&amp;nbsp; std::shared_ptr&amp;lt;op::Layer&amp;gt; embedding_layer_;&lt;br&gt;&lt;br&gt;&amp;nbsp; void to_cuda(std::shared_ptr&amp;lt;kernel::CudaConfig&amp;gt; config);&lt;br&gt;};&lt;/font&gt;" vertex="1">
          <mxGeometry height="430" width="350" x="-1580" y="720" as="geometry" />
        </mxCell>
        <mxCell id="O23gL1ym4Lucq9g-aiCs-101" parent="aN83DGbymWm0B96Egb2V-1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;autosizeText=1;fontSize=11;" value="为什么layers 用 shared_ptr: 容器操作的便利性&lt;br&gt;&lt;br&gt;&amp;nbsp; // vector 中 shared_ptr 更容易处理&lt;br&gt;&amp;nbsp; llama_layers_-&amp;gt;wq_layers_.push_back(wq);&amp;nbsp; // 直接 push&lt;br&gt;&amp;nbsp; llama_layers_-&amp;gt;wq_layers_.at(i);&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // 随意访问和复制&lt;br&gt;&lt;br&gt;&amp;nbsp; // 如果用 unique_ptr&lt;br&gt;&amp;nbsp; llama_layers_-&amp;gt;wq_layers_.push_back(std::move(wq));&amp;nbsp; // 必须 move&lt;br&gt;&amp;nbsp; auto layer = std::move(llama_layers_-&amp;gt;wq_layers_.at(i));&amp;nbsp; // 取出也会转移所有权" vertex="1">
          <mxGeometry height="220" width="330" x="-1550" y="1185" as="geometry" />
        </mxCell>
        <mxCell id="O23gL1ym4Lucq9g-aiCs-106" parent="aN83DGbymWm0B96Egb2V-1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;autosizeText=1;fontSize=6;align=left;" value="&lt;div align=&quot;left&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;// 访问 layer 的 weight 的时候 cast 是按类型的&lt;/font&gt;&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;const void* RawModelDataFp32::weight(size_t offset) const {&lt;br&gt;&amp;nbsp; return static_cas&lt;span style=&quot;color: rgb(255, 51, 51);&quot;&gt;t&amp;lt;float*&amp;gt;&lt;/span&gt;(weight_data) + offset;&lt;br&gt;}&lt;br&gt;const void* RawModelDataInt8::weight(size_t offset) const {&lt;br&gt;&amp;nbsp; return static_cast&amp;lt;int8_t*&amp;gt;(weight_data) + offset;&lt;br&gt;}&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="230" x="-270" y="370" as="geometry" />
        </mxCell>
        <mxCell id="O23gL1ym4Lucq9g-aiCs-107" edge="1" parent="aN83DGbymWm0B96Egb2V-1" source="O23gL1ym4Lucq9g-aiCs-46" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;dashPattern=8 8;" target="O23gL1ym4Lucq9g-aiCs-106">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
